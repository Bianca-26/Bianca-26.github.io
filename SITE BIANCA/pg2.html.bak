<!DOCTYPE html>
<html lang="en">
    <head>
	
        <title> Booklovers </title>
		<style>
body {
				background-image: url('book-gb29b5dd12_1920 - Copy.jpg');
				}
				p.solid {border-style: solid;}
				
.split {
  height: 100%;
  width: 50%;
  position: fixed;
  z-index: 6;
  top: 1;
  overflow-x: hidden;
  padding-top: 100px;
}
.left {
  left: 0;
  background-color:0000ffff ;
}
.right {
  right: 0;
  background-color: 0000ffff;
}
div.slide-left {
  width:100%;
  overflow:hidden;
}
div.slide-left p {
  animation: slide-left 2s;
}

@keyframes slide-left {
  from {
    margin-left: 100%;
    width: 300%; 
  }

  to {
    margin-left: 0%;
    width: 100%;
  }
  
}
body {
            animation: fadeInAnimation ease 1.5s;
            animation-iteration-count: 1;
            animation-fill-mode: forwards;
        }
        @keyframes fadeInAnimation {
            0% {
                opacity: 0;
            }
            100% {
                opacity: 1;
            }
        }
.oval{
         border:2px solid gray;
         background:white;
		 opacity: 50%;
         border-radius:100%;
         width:657px;
         text-align:center;
         color:black;
         padding:172px 0;
         font-size:16px;
		 position: absolute;
         right: 1px;
		 left:60px;
		 top: 50px;
    }
h1 {
  text-shadow: 2px 2px;
  color: black;
}

button {
  margin: 20px;
}
.custom-btn {
  width: 130px;
  height: 40px;
  color: white;
  border-radius: 5px;
  padding: 10px 25px;
  font-family: 'Lato', sans-serif;
  font-weight: 500;
  background: transparent;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  display: inline-block;
   box-shadow:inset 2px 2px 2px 0px rgba(255,255,255,.5),
   7px 7px 20px 0px rgba(0,0,0,.1),
   4px 4px 5px 0px rgba(0,0,0,.1);
  outline: none;
}
.btn-5 {
  width: 130px;
  height: 40px;
  line-height: 42px;
  padding: 0;
  border: none;
  background:#737373;
}
.btn-5:hover {
  color: black;
  background: transparent;
   box-shadow:none;
}
.btn-5:before,
.btn-5:after{
  content:'';
  position:absolute;
  top:0;
  right:0;
  height:2px;
  width:0;
  background: black;
  box-shadow:
   -1px -1px 5px 0px black,
   7px 7px 20px 0px black,
   4px 4px 5px 0px black;
  transition:400ms ease all;
}
.btn-5:after{
  right:inherit;
  top:inherit;
  left:0;
  bottom:0;
}
.btn-5:hover:before,
.btn-5:hover:after{
  width:100%;
  transition:800ms ease all;
}


.btn-6 {
  width: 130px;
  height: 40px;
  line-height: 42px;
  padding: 0;
  border: none;
  background:#737373;
}
.btn-6:hover {
  color: black;
  background: transparent;
   box-shadow:none;
}
.btn-6:before,
.btn-6:after{
  content:'';
  position:absolute;
  top:0;
  right:0;
  height:2px;
  width:0;
  background: black;
  box-shadow:
   -1px -1px 5px 0px black,
   7px 7px 20px 0px black,
   4px 4px 5px 0px black;
  transition:400ms ease all;
}
.btn-6:after{
  right:inherit;
  top:inherit;
  left:0;
  bottom:0;
}
.btn-6:hover:before,
.btn-6:hover:after{
  width:100%;
  transition:800ms ease all;
}

</style>
